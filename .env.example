# Copy to .env and fill in the password (must match POSTGRES_PASSWORD in docker-compose.yml)
DATABASE_URL=postgresql://aqua:<password>@localhost:5432/aqua_life

# Better Auth — generate a secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=<generate-a-32-byte-hex-secret>
BETTER_AUTH_URL=http://localhost:3000

# Seed admin (used by `npm run seed:admin`)
ADMIN_EMAIL=admin@aqua.local
ADMIN_PASSWORD=<choose-a-strong-password>
