{
  "name": "aqua-life-backend",
  "version": "1.0.0",
  "description": "Backend for the Aguajoy project",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch --experimental-strip-types --env-file-if-exists=.env src/server.ts",
    "test": "echo 'Tests are intentionally deferred in this repo (see CLAUDE.md > Testing). No tests to run yet.' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "node --experimental-strip-types --env-file-if-exists=.env scripts/seed-admin.ts"
  },
  "author": "Alex Nepsha",
  "license": "ISC",
  "engines": {
    "node": ">=22.14.0"
  },
  "dependencies": {
    "@scalar/express-api-reference": "^0.10.9",
    "better-auth": "^1.6.23",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "zod": "^4.4.3",
    "zod-openapi": "^6.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
